{
  "name": "loopndroll",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Electrobun desktop starter with React 19, Vite, OXC, and tsgo",
  "scripts": {
    "dev": "concurrently -k -n vite,app \"pnpm run hmr\" \"pnpm run dev:app\"",
    "dev:app": "electrobun dev --watch",
    "dev:hmr": "pnpm run dev",
    "hmr": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build:renderer": "vite build",
    "build": "vite build && electrobun build",
    "lint": "oxlint src electrobun.config.ts vite.config.ts --deny-warnings",
    "lint:fix": "oxlint src electrobun.config.ts vite.config.ts --fix",
    "format": "oxfmt src electrobun.config.ts vite.config.ts",
    "format:check": "oxfmt --check src electrobun.config.ts vite.config.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "check": "pnpm run lint && pnpm run format:check && pnpm run typecheck"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@phosphor-icons/react": "2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electrobun": "1.16.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "7.14.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@typescript/native-preview": "^7.0.0-dev.20260406.1",
    "@vitejs/plugin-react": "^6.0.1",
    "bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tailwindcss": "4.2.2",
    "vite": "^8.0.5"
  }
}
